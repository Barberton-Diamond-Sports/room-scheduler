generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id          String         @id @default(uuid())
  name        String
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  bookings    Booking[]
  blackouts   RoomBlackout[]
}

model AdminUser {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  role            UserRole       @default(ADMIN)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  auditLogs       AuditLog[]
  createdBookings Booking[]      @relation("CreatedBookings")
  updatedBookings Booking[]      @relation("UpdatedBookings")
  blackouts       RoomBlackout[]
}

model Booking {
  id               String        @id @default(uuid())
  roomId           String
  teamId           String?
  bookingDate      DateTime
  startTimeMinutes Int
  endTimeMinutes   Int
  durationBlocks   Int
  title            String?
  notes            String?
  opponent         String?
  status           BookingStatus @default(ACTIVE)
  overrideConflict Boolean       @default(false)
  createdByUserId  String?
  updatedByUserId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  umpireId         String?
  umpireRecord     Umpire?       @relation(fields: [umpireId], references: [id], onDelete: SetNull)
  createdBy        AdminUser?    @relation("CreatedBookings", fields: [createdByUserId], references: [id])
  room             Room          @relation(fields: [roomId], references: [id])
  team             Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  updatedBy        AdminUser?    @relation("UpdatedBookings", fields: [updatedByUserId], references: [id])

  @@index([roomId, bookingDate])
  @@index([bookingDate])
  @@index([umpireId])
  @@index([teamId])
}

model RoomBlackout {
  id              String     @id @default(uuid())
  roomId          String
  startDateTime   DateTime
  endDateTime     DateTime
  reason          String?
  createdByUserId String?
  createdAt       DateTime   @default(now())
  createdBy       AdminUser? @relation(fields: [createdByUserId], references: [id])
  room            Room       @relation(fields: [roomId], references: [id])

  @@index([roomId])
}

model AuditLog {
  id                String     @id @default(uuid())
  entityType        String
  entityId          String
  action            String
  detailsJson       Json?
  performedByUserId String?
  createdAt         DateTime   @default(now())
  performedBy       AdminUser? @relation(fields: [performedByUserId], references: [id])

  @@index([entityType, entityId])
}

model Umpire {
  id           String    @id @default(cuid())
  name         String
  phone        String?
  email        String?
  notes        String?
  doesBaseball Boolean   @default(true)
  doesSoftball Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]

  @@index([isActive])
  @@index([name])
}

model Team {
  id         String     @id @default(cuid())
  teamName   String
  coachName  String
  coachEmail String
  coachPhone String?
  ageGroup   String
  season     TeamSeason
  year       Int
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  bookings   Booking[]

  @@index([teamName])
  @@index([ageGroup])
  @@index([season, year])
  @@index([isActive])
}

enum BookingStatus {
  ACTIVE
  CANCELED
}

enum UserRole {
  ADMIN
  SUPER_ADMIN
}

enum TeamSeason {
  SPRING
  SUMMER
  FALL
}
